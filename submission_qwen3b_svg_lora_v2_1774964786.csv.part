thesantatitan_deepseek-svg-dataset_0004060,"<svg width=""24"" height=""30"" viewBox=""-1 0 -56-97"">
    <!-- Watch face -->
    <circle cx=""8"" cy=""8"" r=""8""/>
    
    <!-- Hour hand -->
    <path d=""
        M 8 8 L 
            8+(-sin(θ)*r/2) + (-cos(θ)*r)/2 , 8+( cos(θ)*r / 2 )""
          fill=""#fff""
          stroke-width="".5""/>

    <!-- Minute hand -->
    <line x1=""8"" y1=""8"" x2=""{x}+"" y2=""{y}"" />
</svg>"
